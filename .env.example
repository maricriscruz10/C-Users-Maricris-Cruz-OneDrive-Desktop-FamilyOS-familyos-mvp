# FamilyOS backend — environment variables
# Copy this file to .env and fill in values before deploying.
# Never commit .env to git.

# ---- Required in production ----

# A long random string used to sign session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=familyos-dev-secret-change-in-prod

# Comma-separated list of allowed frontend origins (no trailing slash).
# Example: CORS_ORIGINS=https://familyos.app,https://www.familyos.app
CORS_ORIGINS=

# ---- Database ----

# Path to store the SQLite database file (defaults to OS temp dir).
# In production swap backend/db.js to use Postgres instead (see docs/HANDOFF.md B6).
# FAMILYOS_DATA_DIR=/data

# Postgres connection string (used once backend/db.js is migrated to Postgres).
# Get this from Supabase → Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ---- Google OAuth (B7) ----
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://your-backend-domain.com/api/auth/google/callback

# ---- Expo Push Notifications (B10) ----
# Get from: expo.dev → Account Settings → Access Tokens
# EXPO_ACCESS_TOKEN=

# ---- Server ----

# Port the backend listens on (default 4000).
# PORT=4000

# Set to 'production' to enable all production guards.
# NODE_ENV=production

# Rate limiting (defaults shown).
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW_MS=60000
